# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # from @BotFather
TELEGRAM_SECRET_TOKEN=        # arbitrary string for webhook verification (auto-generated by onboard script)
ALLOWED_CHAT_IDS=             # comma-separated chat IDs (e.g. 123456789,987654321)

# ── WhatsApp (Bridge) ────────────────────────────────────────
WHATSAPP_ENABLED=false                  # Enable WhatsApp channel via Node.js bridge
WHATSAPP_BRIDGE_URL=ws://localhost:3001 # WebSocket URL for the bridge
WHATSAPP_BRIDGE_TOKEN=                  # Auth token for connection security
WHATSAPP_ALLOW_FROM=                    # Comma-separated allowlist of phone numbers/JIDs

# ── LLM Providers ─────────────────────────────────────────────
GOOGLE_API_KEY=               # Google AI Studio API key
OPENAI_API_KEY=               # OpenAI API key
CLAUDE_API_KEY=               # Anthropic Claude API key
LM_STUDIO_BASE_URL=http://localhost:1234/v1 # Local URL for LM Studio (if applicable)
LM_STUDIO_API_KEY=lm-studio   # Mock API key for LM Studio

# ── Google Workspace ─────────────────────────────────────────
GOOGLE_TOKEN_JSON=            # base64-encoded token.json (production)
                              # or keep token.json on disk (dev)

# ── Observability & Tracing ──────────────────────────────────
LANGCHAIN_TRACING_V2=false    # Set true to export traces to LangSmith
LANGSMITH_API_KEY=
LOGFIRE_TOKEN=

# ── Core Toggleable Settings ─────────────────────────────────
HITL_ENABLED=true                       # Global HITL toggle (false = all tools auto-approved)
DEFAULT_MODEL=openai/gpt-5.4-mini      # Default LLM model (provider/model_name)

# ── Browser Observations & Hardening ─────────────────────────
ENABLE_MULTIMODAL_OBSERVATION=true      # Enable screenshots in tool environment state
STRICT_ACTION_LOOP=true                 # Enforce single stateful action per turn
SMART_SETTLE_OBSERVER=true              # Let browser-use handle DOM watchdog
AUTO_VISUAL_FALLBACK=true               # Fallback to visual parsing if DOM text map fails
STEALTH_MODE=false                      # Anti-detect profiles (if configured)
STICKY_IDS=true                         # Persist DOM node map indexing through re-renders

# ── Worker Limits ────────────────────────────────────────────
WORKER_MAX_STEPS=15                     # Max action steps per Worker task
WORKER_MAX_OBSERVATION_CHARS=50000      # Max chars for environment observation
WORKER_MAX_SKILL_PROMPT_CHARS=10000     # Max chars for skill prompt context

# ── Supervisor Limits ────────────────────────────────────────
SUPERVISOR_TOKEN_BUDGET=6000            # Token budget for message history trimming
SUPERVISOR_CONTENT_TRUNCATION=3000      # Max chars before AI/Tool content is truncated

# ── Scheduler ────────────────────────────────────────────────
SCHEDULER_MAX_CONCURRENT_JOBS=4         # Max cron jobs running concurrently
SCHEDULER_HEARTBEAT_SECONDS=10          # Seconds between scheduler checks
SCHEDULER_RUN_HISTORY_MAX=200           # Max run history records per job
SCHEDULER_RETRY_ENABLED=true            # Enable bounded retry for failed cron runs
SCHEDULER_DELIVERY_ENABLED=true         # Enable output notifications for cron jobs
SCHEDULER_RETRY_MAX_RETRIES=3           # Max retry attempts for cron job failures
SCHEDULER_RETRY_INITIAL_BACKOFF_SECONDS=60 # Initial backoff in seconds
SCHEDULER_RETRY_MAX_BACKOFF_SECONDS=3600   # Max retry backoff in seconds
SCHEDULER_RETRY_JITTER_RATIO=0.2        # Random jitter ratio applied to retry delays
SCHEDULER_SHUTDOWN_GRACE_SECONDS=30     # Worker wait period during shutdown
ALLOW_CRON_SKILL_FALLBACK=false         # Fallback to semantic matching if specific skill missing
